{
  "name": "@novr/bitrise-api",
  "version": "0.2.3",
  "packageManager": "yarn@4.14.1",
  "description": "REST API for Bitrise.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate-client": "openapi-generator-cli generate -i swagger.json -g typescript-fetch -o src/lib",
    "build": "yarn run generate-client && tsc",
    "prepare": "yarn run build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/novr/bitrise-api.git"
  },
  "author": "novr <nobuhisa.komiya@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/novr/bitrise-api/issues"
  },
  "homepage": "https://github.com/novr/bitrise-api#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "chai": "^6.2.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "sinon": "^21.1.2",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
